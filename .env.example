# Copy this file to `.env` and fill in your values.
# The MCP server reads it on startup.

# Required: your Google Cloud project that has the Earth Engine API enabled
# and is registered for Earth Engine use.
EE_PROJECT=ee-your-project-id

# Optional: path to a service-account JSON key. If set, the server uses this
# instead of the user OAuth credential from `earthengine authenticate`.
# EE_SERVICE_ACCOUNT_KEY=C:\path\to\service-account.json
